OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=devops_knowledge

# Set to true when running inside a Kubernetes cluster
K8S_IN_CLUSTER=false
# Path to kubeconfig (leave empty to use default ~/.kube/config)
K8S_KUBECONFIG=

CHUNK_SIZE=800
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=5

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# URL of the help center index page to scrape
HELP_CENTER_INDEX_URL=https://your-help-center.example.com/index.html
